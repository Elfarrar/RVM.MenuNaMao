@page "/admin/menu"
@using RVM.MenuNaMao.Application.Commands
@using RVM.MenuNaMao.Application.DTOs
@using RVM.MenuNaMao.Application.Mediator
@using RVM.MenuNaMao.Domain.Entities
@using RVM.MenuNaMao.Domain.Interfaces
@inject IMediator Mediator
@inject IRestaurantRepository RestaurantRepo
@inject ICategoryRepository CategoryRepo
@inject IMenuItemRepository MenuItemRepo

<h1>Cardápio</h1>

@if (_categories is null)
{
    <p class="loading">Carregando...</p>
}
else
{
    <div class="section">
        <h2>Nova Categoria</h2>
        <div class="inline-form">
            <input @bind="_newCatName" placeholder="Nome" />
            <input @bind="_newCatOrder" type="number" placeholder="Ordem" style="width:80px" />
            <button class="btn-primary-sm" @onclick="AddCategory">Adicionar</button>
        </div>
    </div>

    @foreach (var cat in _categories)
    {
        <div class="section">
            <h2>@cat.Name</h2>

            <div class="inline-form">
                <input @bind="_newItemName" placeholder="Nome do item" />
                <input @bind="_newItemPrice" type="number" step="0.01" placeholder="Preço" style="width:100px" />
                <input @bind="_newItemTime" type="number" placeholder="Min" style="width:70px" />
                <button class="btn-primary-sm" @onclick="() => AddItem(cat.Id)">+ Item</button>
            </div>

            @if (cat.Items.Count > 0)
            {
                <table class="data-table">
                    <thead><tr><th>Item</th><th>Preço</th><th>Tempo</th><th>Disponível</th></tr></thead>
                    <tbody>
                        @foreach (var item in cat.Items)
                        {
                            <tr>
                                <td>@item.Name</td>
                                <td>R$ @item.Price.ToString("N2")</td>
                                <td>@item.PreparationTimeMinutes min</td>
                                <td>@(item.Available ? "Sim" : "Não")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }
}

@code {
    private List<CategoryWithItemsDto>? _categories;
    private Guid _restaurantId;
    private string _newCatName = "";
    private int _newCatOrder;
    private string _newItemName = "";
    private decimal _newItemPrice;
    private int _newItemTime = 15;

    protected override async Task OnInitializedAsync()
    {
        var restaurants = await RestaurantRepo.GetAllAsync();
        if (restaurants.Count > 0)
        {
            _restaurantId = restaurants[0].Id;
            await LoadMenu();
        }
        else
        {
            _categories = [];
        }
    }

    private async Task LoadMenu()
    {
        var cats = await CategoryRepo.GetByRestaurantIdAsync(_restaurantId);
        _categories = [];
        foreach (var cat in cats.OrderBy(c => c.DisplayOrder))
        {
            var items = await MenuItemRepo.GetByCategoryIdAsync(cat.Id);
            _categories.Add(new CategoryWithItemsDto(cat.Id, cat.Name, cat.DisplayOrder,
                items.Select(i => new MenuItemDto(i.Id, i.CategoryId, i.Name, i.Description, i.Price, i.ImageUrl, i.Available, i.PreparationTimeMinutes)).ToList()));
        }
    }

    private async Task AddCategory()
    {
        if (string.IsNullOrWhiteSpace(_newCatName)) return;
        await Mediator.Send(new CreateCategoryCommand(_restaurantId, _newCatName, _newCatOrder));
        _newCatName = "";
        _newCatOrder = 0;
        await LoadMenu();
    }

    private async Task AddItem(Guid categoryId)
    {
        if (string.IsNullOrWhiteSpace(_newItemName)) return;
        await Mediator.Send(new CreateMenuItemCommand(categoryId, _newItemName, null, _newItemPrice, null, _newItemTime));
        _newItemName = "";
        _newItemPrice = 0;
        _newItemTime = 15;
        await LoadMenu();
    }
}
