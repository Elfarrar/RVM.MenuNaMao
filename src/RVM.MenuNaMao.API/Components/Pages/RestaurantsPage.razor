@page "/admin/restaurants"
@using RVM.MenuNaMao.Domain.Entities
@using RVM.MenuNaMao.Domain.Interfaces
@inject IRestaurantRepository RestaurantRepo
@inject NavigationManager Nav

<h1>Restaurantes</h1>

@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert @(_isError ? "alert-danger" : "alert-success")">@_message</div>
}

<div class="section">
    <h2>Novo Restaurante</h2>
    <div class="inline-form">
        <input @bind="_name" placeholder="Nome" />
        <input @bind="_slug" placeholder="Slug (ex: meu-restaurante)" />
        <input @bind="_address" placeholder="Endereço (opcional)" />
        <input @bind="_phone" placeholder="Telefone (opcional)" style="width:140px" />
        <button class="btn-primary-sm" @onclick="Create">Criar</button>
    </div>
</div>

@if (_restaurants is null)
{
    <p class="loading">Carregando...</p>
}
else if (_restaurants.Count == 0)
{
    <div class="alert alert-warning">Nenhum restaurante cadastrado. Crie um para começar.</div>
}
else
{
    <table class="data-table">
        <thead>
            <tr>
                <th>Nome</th>
                <th>Slug</th>
                <th>Endereço</th>
                <th>Telefone</th>
                <th>Ativo</th>
                <th>Link Cardápio</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in _restaurants)
            {
                <tr>
                    <td>
                        @if (_editingId == r.Id)
                        {
                            <input @bind="_editName" class="input-sm" />
                        }
                        else
                        {
                            @r.Name
                        }
                    </td>
                    <td>@r.Slug</td>
                    <td>
                        @if (_editingId == r.Id)
                        {
                            <input @bind="_editAddress" class="input-sm" />
                        }
                        else
                        {
                            @r.Address
                        }
                    </td>
                    <td>
                        @if (_editingId == r.Id)
                        {
                            <input @bind="_editPhone" class="input-sm" style="width:130px" />
                        }
                        else
                        {
                            @r.Phone
                        }
                    </td>
                    <td>
                        <span class="@(r.Active ? "status-active" : "status-inactive")">@(r.Active ? "Sim" : "Não")</span>
                    </td>
                    <td>
                        <a href="/menu/@r.Slug" target="_blank" style="color:var(--accent)">/menu/@r.Slug</a>
                    </td>
                    <td>
                        @if (_editingId == r.Id)
                        {
                            <button class="btn-sm btn-primary" @onclick="() => SaveEdit(r)">Salvar</button>
                            <button class="btn-sm" @onclick="CancelEdit">Cancelar</button>
                        }
                        else
                        {
                            <button class="btn-sm" @onclick="() => StartEdit(r)">Editar</button>
                            <button class="btn-sm @(r.Active ? "btn-danger" : "btn-success")" @onclick="() => ToggleActive(r)">
                                @(r.Active ? "Desativar" : "Ativar")
                            </button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Restaurant>? _restaurants;
    private string _name = "", _slug = "", _address = "", _phone = "";
    private string _message = "";
    private bool _isError;
    private Guid? _editingId;
    private string _editName = "", _editAddress = "", _editPhone = "";

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load() =>
        _restaurants = await RestaurantRepo.GetAllAsync();

    private async Task Create()
    {
        _message = "";
        if (string.IsNullOrWhiteSpace(_name) || string.IsNullOrWhiteSpace(_slug))
        {
            _message = "Nome e Slug são obrigatórios.";
            _isError = true;
            return;
        }

        var existing = await RestaurantRepo.GetBySlugAsync(_slug);
        if (existing is not null)
        {
            _message = $"Já existe um restaurante com o slug '{_slug}'.";
            _isError = true;
            return;
        }

        var restaurant = new Restaurant
        {
            Name = _name,
            Slug = _slug.ToLowerInvariant().Trim(),
            Address = string.IsNullOrWhiteSpace(_address) ? null : _address,
            Phone = string.IsNullOrWhiteSpace(_phone) ? null : _phone
        };

        await RestaurantRepo.AddAsync(restaurant);
        _message = $"Restaurante '{_name}' criado. Acesse o cardápio em /menu/{restaurant.Slug}";
        _isError = false;
        _name = ""; _slug = ""; _address = ""; _phone = "";
        await Load();
    }

    private void StartEdit(Restaurant r)
    {
        _editingId = r.Id;
        _editName = r.Name;
        _editAddress = r.Address ?? "";
        _editPhone = r.Phone ?? "";
    }

    private void CancelEdit()
    {
        _editingId = null;
    }

    private async Task SaveEdit(Restaurant r)
    {
        r.Name = _editName;
        r.Address = string.IsNullOrWhiteSpace(_editAddress) ? null : _editAddress;
        r.Phone = string.IsNullOrWhiteSpace(_editPhone) ? null : _editPhone;
        await RestaurantRepo.UpdateAsync(r);
        _message = $"Restaurante '{r.Name}' atualizado.";
        _isError = false;
        _editingId = null;
        await Load();
    }

    private async Task ToggleActive(Restaurant r)
    {
        r.Active = !r.Active;
        await RestaurantRepo.UpdateAsync(r);
        _message = $"Restaurante '{r.Name}' {(r.Active ? "ativado" : "desativado")}.";
        _isError = false;
        await Load();
    }
}
